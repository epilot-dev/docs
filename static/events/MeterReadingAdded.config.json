{
  "event_name": "MeterReadingAdded",
  "event_title": "Meter Reading Added",
  "event_description": "Triggered for every meter reading added event",
  "event_version": "2.0",
  "event_tags": [
    "builtin",
    "erp",
    "metering"
  ],
  "schema_fields": {
    "activity_type": {
      "json_schema": {
        "type": "string",
        "enum": [
          "MeterReadingsAdded",
          "ChangesetCreated",
          "ChangesetApplied",
          "ChangesetDismissed"
        ],
        "description": "Originating lifecycle action: `MeterReadingsAdded` (direct commit), `ChangesetCreated` (pending), `ChangesetApplied` (pending → committed), or `ChangesetDismissed` (pending rejected)."
      },
      "required": false
    },
    "reading_date": {
      "json_schema": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 timestamp when reading was taken"
      },
      "required": true
    },
    "read_by": {
      "json_schema": {
        "type": "string",
        "description": "Name or identifier of who submitted the reading"
      },
      "required": false
    },
    "reason": {
      "json_schema": {
        "type": "string",
        "description": "Reason for the meter reading"
      },
      "required": false
    },
    "remarks": {
      "json_schema": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Free-text remarks left by the submitter, in reading order (one per counter when multi-counter). Empty / whitespace-only remarks are omitted. Undefined when no reading carried a remark."
      },
      "required": false
    },
    "source": {
      "json_schema": {
        "type": "string",
        "description": "Source system where reading was submitted"
      },
      "required": true
    },
    "reading_source": {
      "json_schema": {
        "type": "string",
        "description": "Source of the meter reading (alias for source)"
      },
      "required": false
    },
    "meter_id": {
      "json_schema": {
        "type": "string",
        "format": "uuid",
        "description": "Entity ID of the meter"
      },
      "required": false
    },
    "contract_number": {
      "json_schema": {
        "type": "string",
        "description": "Contract number associated with the meter"
      },
      "required": false
    },
    "meter_number": {
      "json_schema": {
        "type": "string",
        "description": "Human-readable meter number"
      },
      "required": false
    },
    "obis_numbers": {
      "json_schema": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "OBIS codes of the counters (one per reading)"
      },
      "required": false
    },
    "unit": {
      "json_schema": {
        "type": "string",
        "description": "Unit of measurement (e.g., kWh, m3)"
      },
      "required": false
    },
    "user_id": {
      "json_schema": {
        "type": "string",
        "description": "ID of the user who submitted the reading"
      },
      "required": false
    },
    "user_email": {
      "json_schema": {
        "type": "string",
        "format": "email",
        "description": "Email of the user who submitted the reading"
      },
      "required": false
    },
    "changeset_id": {
      "json_schema": {
        "type": "string",
        "description": "Identifier of the originating changeset, if any"
      },
      "required": false
    },
    "changeset_edit_mode": {
      "json_schema": {
        "type": "string",
        "enum": [
          "direct",
          "external",
          "approval"
        ],
        "description": "Mode under which this reading reached the catalog. `direct` = no changeset (committed straight to ClickHouse). `external` / `approval` = the originating changeset's edit_mode. Always populated, so webhook conditions like `changeset_edit_mode != approval` work deterministically across every activity_type."
      },
      "required": false
    },
    "meter_readings": {
      "json_schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "counter_id": {
              "type": "string",
              "format": "uuid",
              "description": "Entity ID of the meter counter"
            },
            "value": {
              "type": "number",
              "description": "The meter reading value"
            },
            "direction": {
              "type": "string",
              "enum": [
                "feed-in",
                "feed-out"
              ],
              "description": "Direction of energy flow"
            },
            "obis_number": {
              "type": "string",
              "description": "OBIS code of the counter"
            },
            "reading_timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp when the reading was taken"
            },
            "read_by": {
              "type": "string",
              "description": "Name of the person who submitted the reading"
            },
            "reason": {
              "type": "string",
              "description": "Reason for the reading"
            },
            "remark": {
              "type": "string",
              "description": "Additional remarks"
            },
            "status": {
              "type": "string",
              "enum": [
                "valid",
                "implausible"
              ],
              "description": "Status of the meter reading"
            },
            "external_id": {
              "type": "string",
              "description": "External system reference"
            },
            "unit": {
              "type": "string",
              "description": "Unit of measurement (e.g., kWh, m3) entered with the reading"
            }
          },
          "additionalProperties": false
        },
        "description": "Committed meter readings (one entry per counter). Populated only for committed-reading events: `MeterReadingsAdded` and `ChangesetApplied`. Empty / absent on pending and dismissed lifecycle events — see `proposed_meter_readings` for those."
      },
      "required": false
    },
    "meter_reading_status": {
      "json_schema": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "valid",
            "implausible"
          ],
          "description": "Status of the meter reading"
        },
        "description": "Aggregated status array for committed meter readings"
      },
      "required": false
    },
    "proposed_meter_readings": {
      "json_schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "counter_id": {
              "type": "string",
              "format": "uuid",
              "description": "Entity ID of the meter counter"
            },
            "value": {
              "type": "number",
              "description": "Proposed meter reading value"
            },
            "direction": {
              "type": "string",
              "enum": [
                "feed-in",
                "feed-out"
              ],
              "description": "Proposed direction of energy flow"
            },
            "obis_number": {
              "type": "string",
              "description": "OBIS code of the counter (hydrated from meter_counter)"
            },
            "reading_timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "Proposed ISO 8601 timestamp when the reading was taken"
            },
            "read_by": {
              "type": "string",
              "description": "Name of the person who submitted the proposed reading"
            },
            "reason": {
              "type": "string",
              "description": "Reason for the proposed reading (e.g., \"regular\", \"move-in\")"
            },
            "remark": {
              "type": "string",
              "description": "Free-text remark entered by the submitter on the proposed reading"
            },
            "external_id": {
              "type": "string",
              "description": "External system reference carried with the proposed reading"
            },
            "unit": {
              "type": "string",
              "description": "Unit of measurement (e.g., kWh, m3) entered with the proposed reading"
            },
            "status": {
              "type": "string",
              "enum": [
                "valid",
                "implausible"
              ],
              "description": "Validation outcome of the proposed reading, if metering-api ran validation"
            },
            "changeset_id": {
              "type": "string",
              "description": "Unique identifier of the changeset"
            },
            "edit_mode": {
              "type": "string",
              "enum": [
                "external",
                "approval"
              ],
              "description": "Edit mode: external system validation or human approval workflow"
            },
            "created_at": {
              "type": "string",
              "format": "date-time",
              "description": "When the proposed reading was submitted (changeset created)"
            },
            "previous_value": {
              "type": "number",
              "description": "Reading value being overwritten, if any"
            },
            "previous_direction": {
              "type": "string",
              "enum": [
                "feed-in",
                "feed-out"
              ],
              "description": "Direction of the reading being overwritten"
            },
            "previous_timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "Timestamp of the reading being overwritten"
            }
          },
          "required": [
            "changeset_id",
            "edit_mode",
            "created_at"
          ],
          "additionalProperties": false
        },
        "description": "Proposed (pending) meter readings carried by `ChangesetCreated` and `ChangesetDismissed` events. Empty / absent on committed-reading events — see `meter_readings` for those."
      },
      "required": false
    },
    "dismissed_reason": {
      "json_schema": {
        "type": "string",
        "description": "Optional human-supplied reason a pending changeset was dismissed."
      },
      "required": false
    },
    "dismissed_at": {
      "json_schema": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 timestamp when a pending changeset was dismissed."
      },
      "required": false
    }
  },
  "entity_graph": {
    "nodes": [
      {
        "id": "meter",
        "schema": "meter",
        "cardinality": "one"
      },
      {
        "id": "meter_counters",
        "schema": "meter_counter",
        "cardinality": "many"
      },
      {
        "id": "contract",
        "schema": "contract",
        "cardinality": "one"
      },
      {
        "id": "contracts",
        "schema": "contract",
        "cardinality": "many"
      },
      {
        "id": "customer",
        "schema": "contact",
        "cardinality": "one"
      },
      {
        "id": "portal_user",
        "schema": "portal_user",
        "cardinality": "one"
      },
      {
        "id": "billing_account",
        "schema": "billing_account",
        "cardinality": "one"
      }
    ],
    "edges": [
      {
        "from": "meter",
        "to": "meter_counters"
      },
      {
        "from": "meter",
        "to": "contract"
      },
      {
        "from": "meter",
        "to": "contracts"
      },
      {
        "from": "contract",
        "to": "customer"
      },
      {
        "from": "customer",
        "to": "portal_user"
      },
      {
        "from": "contract",
        "to": "billing_account"
      }
    ]
  }
}